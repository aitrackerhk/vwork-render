# Copy to ".env" (DO NOT commit secrets) or set as environment variables.
#
# --- Database ---
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=u-nai
DB_SSLMODE=disable

# --- Server ---
SERVER_PORT=3001
SERVER_HOST=0.0.0.0

# --- Hardware Purchase Catalog ---
HARDWARE_PURCHASE_CATALOG_FILE=config/hardware_purchase_catalog.json

# --- Public Domain ---
# Base domain used for tenant subdomains (e.g. tenant1.<BASE_DOMAIN>)
BASE_DOMAIN=vworkai.com
# Public scheme used when generating absolute URLs in emails, etc.
PUBLIC_SCHEME=https

# ===== Custom Domain (Website) =====
# For customers' custom domains (e.g. www.customer.com), instruct them to create a CNAME to this target.
# This hostname should be on your Cloudflare zone if you plan to use Cloudflare for SaaS / SSL for SaaS.
# Example: cname.vworkai.com
CUSTOM_DOMAIN_CNAME_TARGET=

# ===== Cloudflare for SaaS / Custom Hostnames =====
# Required to auto-create Custom Hostnames and let Cloudflare handle SSL for user domains.
# Create an API token with permissions for the zone: "Zone:Read", "Zone:Edit", "Custom Hostnames:Edit" (names vary).
CLOUDFLARE_API_TOKEN=
# Zone ID for your SaaS zone (e.g. vworkai.com) in Cloudflare dashboard.
CLOUDFLARE_ZONE_ID=

# Background auto-sync (cronjob): once user DNS is correct, auto-create/sync Cloudflare Custom Hostnames until SSL is active.
CF_CUSTOM_DOMAIN_SYNC_INTERVAL_SECONDS=120
CF_CUSTOM_DOMAIN_SYNC_LIMIT=200

# ===== Domain Connect (Cloudflare) =====
# Used for the "auto" DNS setup UX. To truly enable one-click auto DNS:
# 1) Create Domain Connect templates and submit to the official template repository
# 2) Email Cloudflare: domain-connect@cloudflare.com to onboard your templates
# These values are not required for the manual flow.
ENABLE_DOMAIN_CONNECT=false
DOMAIN_CONNECT_PROVIDER_ID=
DOMAIN_CONNECT_TEMPLATE_ID=
#
# Example (for this repo's template):
# DOMAIN_CONNECT_PROVIDER_ID=vwork
# DOMAIN_CONNECT_TEMPLATE_ID=www-cname

# --- Performance / Runtime ---
# Set to "production" for best performance defaults (template reload/debug off, request logger off, GORM log reduced)
APP_ENV=production
# Optional: Fiber prefork (multi-process). Usually helps throughput on multi-core VMs.
FIBER_PREFORK=false
# Optional: re-enable request logger in production (hurts throughput)
APP_REQUEST_LOGGER=false
# Optional: GORM log level override: silent|error|warn|info
GORM_LOG_LEVEL=warn

# --- JWT ---
JWT_SECRET=change-me

# --- Google Maps ---
GOOGLE_MAPS_API_KEY=

# --- SMTP (Email Service Provider) ---
# Supports: Amazon SES, SendGrid, Mailgun, Postmark, Brevo, MailerSend, etc.
# See EMAIL_SERVICE_ALTERNATIVES.md for detailed comparison and setup guides
#
# Amazon SES example:
#   SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
#   SMTP_PORT=587
#   SMTP_USER=your_ses_smtp_username
#   SMTP_PASSWORD=your_ses_smtp_password
#
# SendGrid example:
#   SMTP_HOST=smtp.sendgrid.net
#   SMTP_PORT=587
#   SMTP_USER=apikey
#   SMTP_PASSWORD=your_sendgrid_api_key
#
# Mailgun example:
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=your_mailgun_username
#   SMTP_PASSWORD=your_mailgun_password
#
# MailerSend example (free 12K/month):
#   SMTP_HOST=smtp.mailersend.com
#   SMTP_PORT=587
#   SMTP_USER=your_mailersend_token
#   SMTP_PASSWORD=your_mailersend_token
#
# Brevo (Sendinblue) example (free 300/day):
#   SMTP_HOST=smtp-relay.brevo.com
#   SMTP_PORT=587
#   SMTP_USER=your_login_email@smtp-brevo.com
#   SMTP_PASSWORD=your_smtp_key
#   SMTP_FROM_EMAIL=no-reply@mail.vworkai.com
#   SMTP_FROM_NAME=vWork
#
SMTP_HOST=
SMTP_PORT=587
SMTP_USE_STARTTLS=true
SMTP_INSECURE_SKIP_VERIFY_TLS=false

# SMTP credentials (format depends on service provider)
SMTP_USER=
SMTP_PASSWORD=

# Must be a verified sender email/domain
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=vWork

# Optional: contact form receiver
CONTACT_EMAIL=

# --- Email worker behavior ---
# If true, worker will start even when SMTP is not configured (not recommended in prod)
EMAIL_WORKER_ALLOW_NO_SMTP=false

# --- Email queue sending (now runs inside vwork-cronjob) ---
# Poll interval for fetching email_jobs (milliseconds).
# Recommended: 10000 (10 seconds)
EMAIL_WORKER_POLL_MS=10000
# Concurrency workers for sending emails.
EMAIL_WORKER_CONCURRENCY=5
# Seconds before a "sending" lock is considered stale and can be retried.
EMAIL_WORKER_LOCK_STALE_SECONDS=600

# Optional: specify dotenv path explicitly (useful for services / schedulers)
# ENV_FILE=C:\path\to\.env

# --- LLM (Large Language Model) API ---
# Gemini API Key (用於 AI 對話、字段匹配等功能)
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
LLM_IMAGE_MODEL=imagen-3.0-generate-001
LLM_PROVIDER=gemini
LLM_ENDPOINT=

# --- Google Cloud Vision & Speech-to-Text API ---
# 可以使用同一個 API Key（推薦），或分別配置
# 通用 API Key（如果設置，Vision 和 Speech 都會使用它，除非單獨配置）
GOOGLE_CLOUD_API_KEY=
# 單獨配置 Vision API Key（可選，如果設置會覆蓋通用 API Key）
GOOGLE_VISION_API_KEY=
# 單獨配置 Speech-to-Text API Key（可選，如果設置會覆蓋通用 API Key）
GOOGLE_SPEECH_API_KEY=
# Optional: Google Cloud Project ID (can be used for both Vision and Speech)
GOOGLE_CLOUD_PROJECT_ID=

# --- Google OAuth 2.0 (Login/Register) ---
# 在 Google Cloud Console 建立 OAuth 2.0 客戶端 ID 後填入
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=150732813516-90v6kgagrtcoagdrppr7o0beo69b7f96.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=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
# 是否啟用 Google OAuth 登錄功能
GOOGLE_OAUTH_ENABLED=true

# --- Google AdSense ---
# Publisher ID for displaying ads to free/trial plan users
# Get your publisher ID from https://www.google.com/adsense/
GOOGLE_ADSENSE_PUBLISHER_ID=

# --- Stripe (Payment) ---
# Get your keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional: default subscription price IDs
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
STRIPE_PARTNER_PRODUCT_ID=
# Optional: redirect URLs after checkout
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=

# --- Stripe Connect (讓租戶一鍵連接 Stripe 收款) ---
# 平台對每筆交易的抽成百分比（默認 2%）
STRIPE_CONNECT_APPLICATION_FEE_PERCENT=2.0


